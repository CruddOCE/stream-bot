# Copy this file to .env and fill in the values below.
# Never commit your real .env file.

# --- General ---
BOT_PREFIX=!
# Enable/disable each platform independently
ENABLE_TWITCH=true
ENABLE_YOUTUBE=false
# Port for the local alert/overlay server (add http://localhost:<port>/overlay.html
# as an OBS Browser Source)
ALERT_SERVER_PORT=8090

# --- Twitch ---
# The Twitch account the bot logs in as (must be modded in your channel
# for timeout/ban/delete actions to work: /mod <botname> in your own chat)
TWITCH_BOT_USERNAME=
# Chat token in the form oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get one by running: npm run twitch-auth
TWITCH_OAUTH_TOKEN=
# Your channel name (the channel the bot joins), lowercase, no #
TWITCH_CHANNEL=

# Needed for the twitch-auth helper script AND for !so to look up a
# shoutout target's last-played game (register a free app at
# https://dev.twitch.tv/console/apps — set OAuth Redirect URL to
# http://localhost:3940/callback)
TWITCH_CLIENT_ID=
# Needed only for !so's game lookup (same app as above — generate a
# Client Secret on the same page). Without it, !so still works but skips
# the "last streaming <game>" part.
TWITCH_CLIENT_SECRET=

# --- YouTube ---
# API key from Google Cloud Console (enable "YouTube Data API v3")
YOUTUBE_API_KEY=
# The channel ID of the channel you stream from (starts with UC...)
YOUTUBE_CHANNEL_ID=

# Needed only if you want the bot to post messages / delete messages /
# time out users on YouTube (not just read chat). Register an OAuth 2.0
# Client ID ("Desktop app" type is easiest) in Google Cloud Console, then
# run: npm run yt-auth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
